# chainmail armor
execute if predicate fkbm:mobs/equipment/head_air if predicate fkbmtool:rng/20 run item replace entity @s armor.head with minecraft:chainmail_helmet[damage=140,attribute_modifiers=[{id:"armor",type:"armor",amount:3,operation:"add_value",slot:"armor"}],custom_name={"italic":false,"text":"Heavy Chainmail Helmet"},item_name={"italic":false,"text":"Heavy Chainmail Helmet"}]
execute if predicate fkbm:mobs/equipment/chest_air if predicate fkbmtool:rng/20 run item replace entity @s armor.chest with minecraft:chainmail_chestplate[damage=220,attribute_modifiers=[{id:"armor",type:"armor",amount:6,operation:"add_value",slot:"armor"}],custom_name={"italic":false,"text":"Heavy Chainmail Chestplate"},item_name={"italic":false,"text":"Heavy Chainmail Chestplate"}]
execute if predicate fkbm:mobs/equipment/legs_air if predicate fkbmtool:rng/20 run item replace entity @s armor.legs with minecraft:chainmail_leggings[damage=105,attribute_modifiers=[{id:"armor",type:"armor",amount:5,operation:"add_value",slot:"armor"}],custom_name={"italic":false,"text":"Heavy Chainmail Leggings"},item_name={"italic":false,"text":"Heavy Chainmail Leggings"}]
execute if predicate fkbm:mobs/equipment/feet_air if predicate fkbmtool:rng/20 run item replace entity @s armor.feet with minecraft:chainmail_boots[damage=175,attribute_modifiers=[{id:"armor",type:"armor",amount:2,operation:"add_value",slot:"armor"}],custom_name={"italic":false,"text":"Heavy Chainmail Boots"},item_name={"italic":false,"text":"Heavy Chainmail Boots"}]

