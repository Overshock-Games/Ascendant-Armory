tellraw @s ["",{"storage":"fkbm:text","nbt":"project.print_short","interpret":true},{"text":"- BaseDifficulty","hover_event":{"action":"show_text","value":[{"text":"Change base datapack's difficulty. Higher base difficulty means more skilled mobs and better stats.\n"},{"text":"Default : 1\n","color":"gray"},{"text":"0 : Peacefull (datapack off)\n"},{"text":"1 : Easy (pretty normal mobs + skills)\n"},{"text":"2 : Normal (stronger mobs + skills)\n"},{"text":"3 : Hard (strongest mobs + skills)\n"},{"text":"4 : Auto (world's difficulty)"}]}},{"text":" "},{"text":"[edit]","bold":true,"color":"aqua","click_event":{"action":"suggest_command","command":"/scoreboard players set BaseDifficulty fkbm.options 1"}}]
tellraw @s ["",{"storage":"fkbm:text","nbt":"project.print_short","interpret":true},{"text":"- IndividualDiff","hover_event":{"action":"show_text","value":[{"text":"Change base datapack's difficulty individually for each player.\n"},{"text":"Default : 4\n","color":"gray"},{"text":"0 : Peacefull (datapack off)\n"},{"text":"1 : Easy (pretty normal mobs + gameplay)\n"},{"text":"2 : Normal (stronger mobs + gameplay)\n"},{"text":"3 : Hard (strongest mobs + gameplay)\n"},{"text":"4 : Auto (same as base difficulty)"}]}},{"text":" "},{"text":"[set]","bold":true,"color":"green","click_event":{"action":"suggest_command","command":"/scoreboard players set PLAYER_NAME fkbm.difficulty 4"}},{"text":" "},{"text":"[reset]","bold":true,"color":"green","click_event":{"action":"suggest_command","command":"/scoreboard players reset PLAYER_NAME fkbm.difficulty"}}]
